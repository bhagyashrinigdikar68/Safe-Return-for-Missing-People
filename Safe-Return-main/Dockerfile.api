# ── Dockerfile.api  (Flask face recognition – port 5000) ──
FROM python:3.10-slim

WORKDIR /app

# System dependencies for DeepFace / OpenCV (fixed for Debian trixie)
RUN apt-get update && apt-get install -y \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN mkdir -p temp_uploads uploads/photos data

EXPOSE 5000
CMD ["python", "api.py"]
